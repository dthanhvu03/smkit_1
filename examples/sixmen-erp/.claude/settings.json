{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/id_rsa)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(php artisan migrate:fresh:*)",
      "Bash(php artisan db:wipe:*)",
      "Bash(docker compose down -v:*)",
      "Bash(docker volume prune:*)",
      "Bash(docker volume rm:*)",
      "Bash(chmod -R 777:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(php artisan migrate:*)",
      "Bash(php artisan db:seed:*)",
      "Bash(docker compose down:*)",
      "Bash(docker compose up:*)",
      "Bash(docker system prune:*)",
      "Bash(composer require:*)",
      "Bash(composer update:*)",
      "Edit(./database/migrations/**)",
      "Edit(./modules/**/database/migrations/**)",
      "Write(./.env)"
    ],
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(php artisan test:*)",
      "Bash(./vendor/bin/pint:*)",
      "Bash(./vendor/bin/phpstan:*)",
      "Bash(php artisan route:list)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .cursor/bootstrap/claude-session-digest.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .cursor/bootstrap/guard-pretooluse.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .cursor/bootstrap/sanitize-tool-output.sh"
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .cursor/bootstrap/sanitize-tool-output.sh"
          }
        ]
      }
    ]
  }
}
