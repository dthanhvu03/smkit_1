{
  "name": "@zusem/smkit",
  "version": "0.1.5",
  "description": "Guardrails and consistency for AI coding agents — for everyone, on any stack. One source generates config for Claude Code, Cursor, Copilot, Windsurf, and the AGENTS.md standard.",
  "type": "module",
  "bin": {
    "smkit": "tools/kitgen/cli.mjs"
  },
  "scripts": {
    "init": "node tools/kitgen/init.mjs",
    "build": "node tools/kitgen/kitgen.mjs build",
    "check": "node tools/kitgen/kitgen.mjs check",
    "doctor": "node tools/kitgen/kitgen.mjs doctor",
    "test": "node --test \"tools/kitgen/*.test.mjs\""
  },
  "files": [
    "engine",
    "profiles",
    "tools",
    ".kit/hooks",
    ".kit/constitution.template.md",
    ".kit/decisions.template.md",
    ".kit/task.template.md",
    ".kit/handoff.template.md",
    "kit.config.yaml",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "claude-code",
    "cursor",
    "agents",
    "vibe-coding",
    "guardrails",
    "scaffolding"
  ],
  "license": "Apache-2.0"
}
